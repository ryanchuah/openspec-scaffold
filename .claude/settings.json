{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "\"$CLAUDE_PROJECT_DIR/scripts/test-gate.sh\"",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
